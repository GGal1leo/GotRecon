{
  "name": "gotrecon",
  "version": "1.0.0",
  "description": "GotRecon? — Target Recon Dashboard (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron . --enable-features=UseOzonePlatform --ozone-platform=wayland --enable-wayland-ime",
    "start:x11": "electron . --ozone-platform=x11",
    "build": "electron-builder"
  },
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.gotrecon.app",
    "productName": "GotRecon?",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "modules/**/*"
    ],
    "linux": {
      "target": "AppImage",
      "icon": "assets/gotrecon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/gotrecon.png"
    },
    "win": {
      "target": "nsis"
    }
  }
}
